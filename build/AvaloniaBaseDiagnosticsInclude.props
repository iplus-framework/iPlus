<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Condition="'$(UseAvaloniaFork)' != 'True'">
    <!-- Only include Avalonia.Diagnostics if NOT using standalone DataGrid (to avoid internal DataGrid conflict) -->
    <!-- <Reference Condition="'$(Configuration)' == 'Debug' AND '$(UseStandaloneDataGrid)' != 'True'" Include="Avalonia.Diagnostics">
      <HintPath>$(AvaloniaRootDir)/src/Avalonia.Diagnostics/bin/$(Configuration)/$(AvaloniaBuildFramework)/Avalonia.Diagnostics.dll</HintPath>
    </Reference> -->
    <!-- Do not add diagnostics in fork/source mode; the NuGet package pulls Avalonia 11 buildTransitive targets. -->
    <PackageReference Include="Avalonia.Diagnostics"/>
  </ItemGroup>
</Project> 