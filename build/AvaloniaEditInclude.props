<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup>
    <Reference Include="AvaloniaEdit">
      <HintPath>$(AvaloniaEditIncludeDir)/AvaloniaEdit/bin/$(Configuration)/$(AvaloniaBuildFramework)/AvaloniaEdit.dll</HintPath>
      <Private>true</Private>
    </Reference>
		<Reference Include="AvaloniaEdit.TextMate">
			<HintPath>$(AvaloniaEditIncludeDir)/AvaloniaEdit.TextMate/bin/$(Configuration)/$(AvaloniaBuildFramework)/AvaloniaEdit.TextMate.dll</HintPath>
			<Private>true</Private>
		</Reference>
		<None Include="$(AvaloniaEditIncludeDir)/AvaloniaEdit.TextMate/bin/$(Configuration)/$(AvaloniaBuildFramework)/AvaloniaEdit.TextMate.dll">
			<Link>AvaloniaEdit.TextMate.dll</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</None>
  </ItemGroup>
</Project> 