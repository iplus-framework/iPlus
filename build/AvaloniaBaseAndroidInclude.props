<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <AvaloniaAndroidHintPath Condition="Exists('$(AvaloniaRootDir)/src/Android/Avalonia.Android/bin/$(AvaloniaForkBuildConfiguration)/$(AvsCurrentAndroidTargetFramework)/Avalonia.Android.dll')">$(AvaloniaRootDir)/src/Android/Avalonia.Android/bin/$(AvaloniaForkBuildConfiguration)/$(AvsCurrentAndroidTargetFramework)/Avalonia.Android.dll</AvaloniaAndroidHintPath>
    <AvaloniaAndroidHintPath Condition="'$(AvaloniaAndroidHintPath)' == '' AND Exists('$(AvaloniaRootDir)/src/Android/Avalonia.Android/bin/$(Configuration)/$(AvsCurrentAndroidTargetFramework)/Avalonia.Android.dll')">$(AvaloniaRootDir)/src/Android/Avalonia.Android/bin/$(Configuration)/$(AvsCurrentAndroidTargetFramework)/Avalonia.Android.dll</AvaloniaAndroidHintPath>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="Avalonia.Android" Condition="'$(AvaloniaAndroidHintPath)' != ''">
      <HintPath>$(AvaloniaAndroidHintPath)</HintPath>
    </Reference>
  </ItemGroup>
</Project> 