<ResourceDictionary
   xmlns="https://github.com/avaloniaui"
   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
   xmlns:local="clr-namespace:gip.core.layoutengine.avui"
   xmlns:OutlineView="clr-namespace:gip.ext.designer.avui.OutlineView;assembly=gip.ext.designer.avui"
   xmlns:PropertyGrid="clr-namespace:gip.ext.designer.avui.PropertyGrid;assembly=gip.ext.designer.avui"
   xmlns:Controls="clr-namespace:gip.ext.designer.avui.Controls;assembly=gip.ext.designer.avui">

  <ControlTheme x:Key="{x:Type local:VBMultiBindingEditor}" TargetType="{x:Type local:VBMultiBindingEditor}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate>
          <local:VBGrid>
            <Grid.RowDefinitions>
              <RowDefinition Height="*" MinHeight="100" />
              <RowDefinition Height="30" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <local:VBListBox x:Name="PART_BindingList" 
                             ItemsSource="{Binding Path=BindingsCollection}" 
                             ShowCaption="False">
              <ListBox.ItemTemplate>
                <DataTemplate DataType="OutlineView:BindingEditorWrapperSingle">
                  <local:VBTextBlock Text="{Binding Description}" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </local:VBListBox>
            <Grid Grid.Row="1" ColumnDefinitions="*,*">
              <local:VBButton x:Name="PART_AddItem" Content="Add" Margin="2,0,1,0" Grid.Column="0" MaxHeight="30" />
              <local:VBButton x:Name="PART_RemoveItem" Content="Remove" Margin="1,0,0,0" Grid.Column="1" MaxHeight="30" />
            </Grid>
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Vertical">
              <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                <local:VBTextBlock Text="Converter:" 
                                   Width="100" 
                                   TextTrimming="CharacterEllipsis" 
                                   VerticalAlignment="Center"
                                   IsVisible="{Binding Path=ConverterEditor, Converter={x:Static ObjectConverters.IsNotNull}}" />
                <ContentControl x:Name="ConverterEditor" Content="{Binding Path=ConverterEditor}" />
              </StackPanel>

              <Expander Header="Additional" Margin="0,0,0,6">
                <local:VBScrollViewer MaxHeight="200">
                  <StackPanel>
                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=Mode.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=Mode.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=StringFormat.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=StringFormat.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=ConverterParameter.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=ConverterParameter.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=ConverterCulture.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=ConverterCulture.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=Priority.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=Priority.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=RelativeSource.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=RelativeSource.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=FallbackValue.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=FallbackValue.Editor}" />
                    </Grid>

                    <Grid Margin="0,0,0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>
                      <local:VBTextBlock Grid.Column="0"
                                         Text="{Binding Path=TargetNullValue.Name}"
                                         TextTrimming="CharacterEllipsis"
                                         VerticalAlignment="Center" />
                      <ContentControl Grid.Column="1"
                                      Content="{Binding Path=TargetNullValue.Editor}" />
                    </Grid>
                  </StackPanel>
                </local:VBScrollViewer>
              </Expander>

              <ContentControl x:Name="PART_BindingEditor" />
            </StackPanel>
          </local:VBGrid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </ControlTheme>
</ResourceDictionary>
