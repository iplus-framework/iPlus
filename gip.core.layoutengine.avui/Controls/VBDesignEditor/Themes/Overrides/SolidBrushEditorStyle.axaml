<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:gip.core.layoutengine.avui"
                    xmlns:Controls="clr-namespace:gip.ext.designer.avui.Controls;assembly=gip.ext.designer.avui"
                    xmlns:ControlConvertors="clr-namespace:gip.ext.designer.avui.Controls.Converters;assembly=gip.ext.designer.avui"
                    xmlns:Converters="clr-namespace:gip.ext.designer.avui.Converters;assembly=gip.ext.designer.avui"
                    xmlns:BrushEditor="clr-namespace:gip.ext.designer.avui.PropertyGrid.Editors.BrushEditor;assembly=gip.ext.designer.avui"
                    xmlns:Designer="clr-namespace:gip.ext.designer.avui;assembly=gip.ext.designer.avui">

  <ControlTheme x:Key="{x:Type BrushEditor:SolidBrushEditor}" TargetType="BrushEditor:SolidBrushEditor">
    <Setter Property="Template">
      <ControlTemplate TargetType="BrushEditor:SolidBrushEditor">
        <local:VBTabControl>
          <local:VBTabItem Header="Color Picker">
            <ColorPicker Color="{Binding Color, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
          </local:VBTabItem>
          <local:VBTabItem Header="Color List">
            <local:VBListBox ItemsSource="{Binding AvailableColors}"
                     SelectedItem="{Binding SelectedColorItem, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="400">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <Border Background="{Binding Brush}"
                            Width="20"
                            Height="15"
                            Margin="2"
                            BorderThickness="1"
                            BorderBrush="Gray" />
                    <TextBlock Text="{Binding Name}"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0" />
                  </StackPanel>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </local:VBListBox>
          </local:VBTabItem>
        </local:VBTabControl>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
