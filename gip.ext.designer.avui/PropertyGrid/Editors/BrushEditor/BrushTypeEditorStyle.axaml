<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:BrushEditor="clr-namespace:gip.ext.designer.avui.PropertyGrid.Editors.BrushEditor">

  <ControlTheme x:Key="{x:Type BrushEditor:BrushTypeEditor}" TargetType="BrushEditor:BrushTypeEditor">
    <Setter Property="Template">
      <ControlTemplate TargetType="BrushEditor:BrushTypeEditor">
        <Border BorderThickness="1"
                BorderBrush="Black"
                Background="Transparent"
                HorizontalAlignment="Left"
                Cursor="Hand"
                Width="30"
                Height="16">
          <Border Background="{Binding Value}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
