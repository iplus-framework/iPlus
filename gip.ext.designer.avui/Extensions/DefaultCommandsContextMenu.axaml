<ContextMenu x:Class="gip.ext.designer.avui.Extensions.DefaultCommandsContextMenu"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cmd="clr-namespace:gip.ext.designer.avui"
			 xmlns:Translation="clr-namespace:gip.ext.design.avui.Designer">
	<MenuItem Command="{x:Static cmd:ApplicationCommands.Cut}" CommandParameter="{Binding .}" Header="{Binding Cut, Source={x:Static Translation:Translations.Instance}}">
		<MenuItem.Icon>
			<Image Source="avares://gip.ext.designer.avui/Images/Icons.16x16.CutIcon.png" />
		</MenuItem.Icon>
	</MenuItem>
	<MenuItem Command="{x:Static cmd:ApplicationCommands.Copy}" CommandParameter="{Binding .}" Header="{Binding Copy, Source={x:Static Translation:Translations.Instance}}">
		<MenuItem.Icon>
			<Image Source="avares://gip.ext.designer.avui/Images/Icons.16x16.CopyIcon.png" />
		</MenuItem.Icon>
	</MenuItem>
	<MenuItem Command="{x:Static cmd:ApplicationCommands.Paste}" CommandParameter="{Binding .}" Header="{Binding Paste, Source={x:Static Translation:Translations.Instance}}">
		<MenuItem.Icon>
			<Image Source="avares://gip.ext.designer.avui/Images/Icons.16x16.PasteIcon.png" />
		</MenuItem.Icon>
	</MenuItem>
	<Separator />
	<MenuItem Command="{x:Static cmd:ApplicationCommands.Delete}" CommandParameter="{Binding .}" Header="{Binding Delete, Source={x:Static Translation:Translations.Instance}}">
		<MenuItem.Icon>
			<Image Source="avares://gip.ext.designer.avui/Images/Icons.16x16.DeleteIcon.png" />
		</MenuItem.Icon>
	</MenuItem>
	<Separator />
	<MenuItem Command="{x:Static cmd:ApplicationCommands.Undo}" CommandParameter="{Binding .}" Header="{Binding Undo, Source={x:Static Translation:Translations.Instance}}">
		<MenuItem.Icon>
			<Image Source="avares://gip.ext.designer.avui/Images/Icons.16x16.UndoIcon.png" />
		</MenuItem.Icon>
	</MenuItem>
	<MenuItem Command="{x:Static cmd:ApplicationCommands.Redo}" CommandParameter="{Binding .}" Header="{Binding Redo, Source={x:Static Translation:Translations.Instance}}">
		<MenuItem.Icon>
			<Image Source="avares://gip.ext.designer.avui/Images/Icons.16x16.RedoIcon.png" />
		</MenuItem.Icon>
	</MenuItem>
</ContextMenu>
